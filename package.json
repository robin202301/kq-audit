{
  "name": "auditsystem-win",
  "version": "0.1.0",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "start": "npm run electron:dev",
    "electron:dev": "concurrently -k \"npm run dev\" \"tsc -p tsconfig.main.json -w\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    /* 修正：在打包前先执行 build 确保代码是最新的 */
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "docxtemplater": "^3.42.0",
    "pizzip": "^3.1.0",
    "sqlite3": "^5.1.0",
    "vue": "^3.4.0",
    "pinia": "^2.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.kqq.auditsystem",
    "productName": "KQQ-Audit-System",
    "npmRebuild": false,    // 禁用自动安装重编
    "nodeGypRebuild": false, // 禁用 gyp 自动重编
    "directories": {
      "output": "release" 
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/templates",
        "to": "templates",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    }
  }
}
